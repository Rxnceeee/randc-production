# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=3000

# URLs
APP_URL=https://YOUR-BACKEND.hostinger.app
# Comma-separated list of allowed frontend origins (Vercel domain + custom domain)
ALLOWED_ORIGINS=https://YOUR-APP.vercel.app,https://yourdomain.com

# Database
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/document_processing

# JWT
JWT_SECRET=replace-with-a-long-random-secret

# Gmail OAuth (for Nodemailer)
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
EMAIL_USER=
